# === Copiá este archivo como .env y completá los valores ===

# Base de datos.
# LOCAL (SQLite):
DATABASE_URL="file:./dev.db"
# NUBE (Postgres) - ejemplo con Neon/Supabase:
# DATABASE_URL="postgresql://usuario:password@host:5432/basedatos?sslmode=require"

# Credenciales de acceso a la plataforma
ADMIN_USER="admin"
ADMIN_PASSWORD="admin"

# Secreto para firmar sesiones. Generá uno largo y aleatorio para producción.
AUTH_SECRET="cambia-esto-por-una-cadena-larga-y-aleatoria"
