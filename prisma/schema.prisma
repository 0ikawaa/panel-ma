// Esquema de base de datos - Plataforma MA Importaciones
// Base de datos real (SQLite en local; ver README para pasar a Postgres en la nube)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

/// Un contenedor / arribo. Cada uno agrupa las líneas cargadas desde un Excel.
model Container {
  id         String    @id @default(cuid())
  name       String // Ej: "Contenedor 1 - Julio 2026"
  supplier   String? // Proveedor (opcional)
  eta        DateTime? // Fecha estimada de arribo (opcional)
  notes      String? // Notas (opcional)
  totalPrice Float? // Precio total del contenedor (fila "TOTAL" del Excel)
  freightCost Float? // Costo del flete del contenedor (USD)
  receivedAt DateTime? // Fecha en que ingresó al depósito (null = en camino)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  products   Product[]

  @@index([receivedAt])
}

/// Una línea del Excel (un producto dentro de un contenedor).
/// Un ítem del contenedor. Puede agrupar varias líneas del Excel (mismo código
/// base, o líneas que comparten una foto combinada). El detalle por talle/línea
/// queda en `detalle`.
model Product {
  id              String    @id @default(cuid())
  containerId     String
  container       Container @relation(fields: [containerId], references: [id], onDelete: Cascade)
  rowIndex        Int // Orden de aparición en el Excel
  photo           String? // Foto en base64 (data URL) extraída de la celda
  codigo          String? // Código a mostrar (base cuando hay varios)
  precioChina     Float? // Precio unitario FOB (USD), representativo
  cantidadPorCaja Int? // Unidades por caja (QTY/CTN) de la primera línea
  unidades        Int? // Unidades totales que llegan (Quantity)
  montoTotal      Float? // Precio del lote (Amount)
  unidad          String? // Unidad: pc / Pair / SET…
  remark          String? // Observaciones combinadas
  cbmUnitario     Float?
  cbmTotal        Float? // CBM total del ítem (suma)
  detalle         Json? // Desglose por línea/talle: [{codigos, unidades, monto, cbmTotal, remark}]
  createdAt       DateTime  @default(now())

  @@index([containerId])
}

/// Usuario de la plataforma con acceso por módulos.
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String?
  modules      String[] // ["inicio","embarques","buscar","admin"]
  createdAt    DateTime @default(now())
}
